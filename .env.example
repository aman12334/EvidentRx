# EvidentRx — Environment configuration
# Copy to .env and fill in your values before running locally.
#
#   cp .env.example .env
#
# For Docker Compose:  docker compose up -d
# For local uvicorn:   uvicorn api.main:app --reload --port 8000

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
# For Docker Compose the host is "db"; for local Python it is "localhost"
DATABASE_URL=postgresql+asyncpg://evidentrx:evidentrx@localhost:5432/evidentrx
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Auth ──────────────────────────────────────────────────────────────────────
# Must be ≥ 32 chars. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=dev_secret_key_change_this_before_any_deploy_32c
SECRET_SIGNING_KEY=dev_signing_key_change_this_before_any_deploy

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── LLM providers (optional — AI features disabled if not set) ────────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ── AWS (optional — secrets manager + S3 backup disabled if not set) ─────────
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# S3_BUCKET=evidentrx-backups-dev
# S3_REGION=us-east-1

# ── Observability (optional) ──────────────────────────────────────────────────
# OTLP_ENDPOINT=http://localhost:4317
